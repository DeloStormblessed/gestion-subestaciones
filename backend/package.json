{
  "name": "gestion-subestaciones-backend",
  "version": "0.1.0",
  "description": "API REST de gestión de mantenimiento de subestaciones eléctricas (GMAO)",
  "type": "module",
  "scripts": {
    "dev": "node --watch server.js",
    "start": "node server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "prisma migrate dev",
    "db:seed": "node prisma/seed.js",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "test:api": "newman run postman/gestion-subestaciones.postman_collection.json -e postman/gestion-subestaciones.postman_environment.json"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "newman": "^6.2.2",
    "prisma": "^5.22.0",
    "supertest": "^7.0.0",
    "vitest": "^2.1.8"
  }
}
