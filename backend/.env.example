# Conexión a PostgreSQL (formato estándar de Prisma).
# El usuario, contraseña y nombre de BD vienen de docker-compose.yml.
DATABASE_URL="postgresql://gmao:gmao_dev_password@localhost:5432/gestion_subestaciones"

# Secreto para firmar tokens JWT. EN PRODUCCIÓN: usar un valor aleatorio largo.
# Para desarrollo local, cualquier cadena vale, pero NUNCA subir el .env real a git.
JWT_SECRET="cambia-esto-en-produccion-con-un-valor-aleatorio-largo"

# Puerto del servidor HTTP.
PORT=3000

# URL del webhook de n8n. Vacía = no se dispara notificación (modo desarrollo).
# Cuando configuremos n8n: poner la URL del webhook aquí.
WEBHOOK_URL=""
