            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }],
            "url": {
              "raw": "{{baseUrl}}/etiquetas/{{etiquetaId}}",
              "host": ["{{baseUrl}}"],
              "path": ["etiquetas", "{{etiquetaId}}"]
            }
          }
        },
        {
          "name": "[demo 403] Tecnico intenta borrar etiqueta",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const req = { url: pm.environment.get('baseUrl') + '/etiquetas', method: 'GET', header: { Authorization: 'Bearer ' + pm.environment.get('tokenOperario') } };",
                  "pm.sendRequest(req, (err, res) => {",
                  "  if (err) { console.error(err); return; }",
                  "  const arr = res.json() || [];",
                  "  if (arr.length > 0) pm.variables.set('cualquierEtiquetaId', arr[0].id);",
                  "});"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 403 (DELETE etiqueta es ADMIN-only)', () => pm.response.to.have.status(403));"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenTecnico}}" }],
            "url": {
              "raw": "{{baseUrl}}/etiquetas/{{cualquierEtiquetaId}}",
              "host": ["{{baseUrl}}"],
              "path": ["etiquetas", "{{cualquierEtiquetaId}}"]
            }
          }
        }
      ]
