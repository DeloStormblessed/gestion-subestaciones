          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenOperario}}" }],
            "url": {
              "raw": "{{baseUrl}}/subestaciones?pagina=1&limite=10",
              "host": ["{{baseUrl}}"],
              "path": ["subestaciones"],
              "query": [
