        {
          "name": "Detalle (primera del listado)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const req = { url: pm.environment.get('baseUrl') + '/subestaciones', method: 'GET', header: { Authorization: 'Bearer ' + pm.environment.get('tokenOperario') } };",
                  "pm.sendRequest(req, (err, res) => {",
                  "  if (err) { console.error(err); return; }",
                  "  const datos = res.json().datos || [];",
                  "  if (datos.length > 0) pm.variables.set('primeraSubId', datos[0].id);",
                  "});"
